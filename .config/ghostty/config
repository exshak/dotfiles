adjust-cell-width = -1
background-opacity = 0.9
command = /opt/homebrew/bin/zsh
confirm-close-surface = false
font-family = Hack Nerd Font
font-size = 12
font-thicken = true
keybind = super+c=text:\x01\x63
keybind = super+d=text:\x01\x5f
keybind = super+shift+d=text:\x01\x2d
keybind = super+shift+r=reload_config
keybind = super+digit_1=text:\x01\x31
keybind = super+digit_2=text:\x01\x32
keybind = super+digit_3=text:\x01\x33
keybind = super+digit_4=text:\x01\x34
keybind = super+digit_5=text:\x01\x35
keybind = super+digit_6=text:\x01\x36
keybind = super+digit_7=text:\x01\x37
keybind = super+digit_8=text:\x01\x38
keybind = super+digit_9=text:\x01\x39
macos-icon = xray
macos-option-as-alt = true
macos-window-shadow = false
maximize = true
mouse-hide-while-typing = true
theme = Dracula
window-decoration = false
window-padding-balance = true
window-padding-x = 0
window-padding-y = 0
