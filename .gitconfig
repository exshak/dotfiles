[alias]
	aliases = config --get-regexp alias
	amend = commit --amend --reuse-message=HEAD
	branches = branch -a
	c = clone --recursive
	contributors = shortlog --summary --numbered
	l = log --oneline --graph -n 20
	p = pull --recurse-submodules
	remotes = remote -v
	s = status -s
	tags = tag -l
	whoami = config user.email
[apply]
	whitespace = fix
[core]
	editor = $EDITOR
	excludesFile = ~/.gitignore
	pager = diff-so-fancy | less --tabs=4 -RFX
	trustctime = false
	untrackedCache = true
[color]
	ui = true
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = red
[color "diff"]
	meta = 11 bold
	frag = magenta bold
	func = 146 bold
	commit = yellow bold
	old = red bold
	new = green bold
	plain = 240
	whitespace = red reverse
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[color "status"]
	header = 240
	branch = yellow
	added = green
	changed = red
	untracked = blue
[commit]
	gpgSign = true
[diff]
	algorithm = patience
	renames = copies
	tool = nvimdiff
[difftool "nvimdiff"]
	cmd = nvim -d $LOCAL $REMOTE
[help]
	autoCorrect = 1
[interactive]
	diffFilter = diff-so-fancy --patch
[merge]
	log = true
	tool = nvimmerge
[mergetool]
	keepBackup = false
[mergetool "nvimmerge"]
	cmd = nvim -d $LOCAL $BASE $REMOTE $MERGED -c 'winc J | winc ='
	trustExitCode = true
[push]
	followTags = true
[url "git@github.com:"]
	insteadOf = "g:"
	pushInsteadOf = "g:"
	insteadOf = "https://github.com/"
[user]
	name = exshak
	email = sbijabhai@gmail.com
